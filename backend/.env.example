# Agent-Arena Backend Configuration
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://agentarena:securepassword123@localhost:5432/agent_arena

# For Docker Compose:
# DATABASE_URL=postgresql://agentarena:securepassword123@postgres:5432/agent_arena

DB_USER=agentarena
DB_PASSWORD=securepassword123
DB_NAME=agent_arena
DB_HOST=localhost
DB_PORT=5432

# ============================================
# Supabase Configuration (Optional)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "https://yourdomain.com"]

# ============================================
# Frontend Configuration
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:10000
NODE_ENV=development

# ============================================
# Email Configuration (SendGrid)
# ============================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDER_EMAIL=noreply@yourdomain.com

# ============================================
# AWS S3 Configuration (For media uploads)
# ============================================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# ============================================
# Redis Configuration (Optional)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Environment
# ============================================
ENVIRONMENT=development
DEBUG=True

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO

# ============================================
# Security
# ============================================
ALLOWED_HOSTS=["localhost", "127.0.0.1", "yourdomain.com"]
