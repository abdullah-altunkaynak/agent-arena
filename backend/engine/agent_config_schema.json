{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Agent Config",
    "description": "Schema for agent config.json — supports lightweight, api_powered, and heavyweight agent types.",
    "type": "object",
    "required": ["name", "description", "agent_type"],
    "properties": {
        "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 64,
            "description": "Display name of the agent."
        },
        "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500,
            "description": "Short description of the agent's purpose."
        },
        "agent_type": {
            "type": "string",
            "enum": ["lightweight", "api_powered", "heavyweight"],
            "description": "The tier of this agent: lightweight (rule-based), api_powered (BYOK LLM), or heavyweight (custom trained model)."
        },
        "system_prompt": {
            "type": "string",
            "description": "System prompt for API-powered agents or context description for others."
        },
        "tools": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true,
            "description": "List of function names the agent can call from its tools module."
        },
        "model": {
            "type": "object",
            "description": "Model configuration for heavyweight agents.",
            "properties": {
                "framework": {
                    "type": "string",
                    "enum": ["pytorch", "tensorflow", "onnx", "custom"],
                    "description": "ML framework used for the model."
                },
                "weights_path": {
                    "type": "string",
                    "description": "Relative path to weights file inside the agent folder (e.g. weights/model.pt)."
                },
                "model_class": {
                    "type": "string",
                    "description": "Python class name to instantiate from the agent's model code."
                },
                "input_format": {
                    "type": "string",
                    "enum": ["json", "tensor", "numpy"],
                    "description": "How to serialise scenario state for model input."
                }
            }
        },
        "inference": {
            "type": "object",
            "description": "Inference backend configuration.",
            "properties": {
                "backend": {
                    "type": "string",
                    "enum": ["local", "ollama", "openai", "anthropic", "custom_endpoint"],
                    "description": "Where/how the agent runs inference."
                },
                "device": {
                    "type": "string",
                    "enum": ["cpu", "cuda", "mps"],
                    "description": "Hardware device for local inference."
                },
                "endpoint_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL for custom_endpoint"
                },
                "ollama_model": {
                    "type": "string",
                    "description": "Ollama model name (e.g. llama3, mistral)."
                }
            }
        },
        "author": {
            "type": "string",
            "description": "GitHub username or display name of the contributor."
        },
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Semantic version of the agent (e.g. 1.0.0)."
        }
    },
    "additionalProperties": false
}
