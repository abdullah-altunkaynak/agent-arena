# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example goes to Git.

# ── API Keys (BYOK — users supply their own keys via the frontend) ──────────
# These are only needed if you run API-powered agents server-side during testing.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (for local LLM inference) ────────────────────────────────────────
# Default Ollama URL when running locally
OLLAMA_BASE_URL=http://localhost:11434

# ── App settings ─────────────────────────────────────────────────────────────
# Set to "production" in deployment
APP_ENV=development
